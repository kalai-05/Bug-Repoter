# Copy to .env and fill in your values. Never commit .env to git.

# ClickUp (stored in chrome.storage.sync at runtime, not used at build time)
VITE_CLICKUP_API_TOKEN=your_clickup_api_token_here
VITE_CLICKUP_WORKSPACE_ID=your_workspace_id
VITE_CLICKUP_SPACE_ID=your_space_id
VITE_CLICKUP_LIST_ID=your_list_id

# Google OAuth (client_id goes in manifest.json oauth2.client_id)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
VITE_GOOGLE_DRIVE_FOLDER_ID=optional_folder_id
